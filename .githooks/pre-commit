#!/usr/bin/env bash
# Auto-rebuild the HPM bundle when a library (or the builder) is staged, so the committed
# bundles/mcp-libraries.zip can never drift from libraries/*.groovy. This keeps the sandbox-lint
# drift gate green and guarantees the CI e2e job installs the proper, full, current bundle (it
# downloads the committed zip at the PR head SHA -- a stale commit would test outdated library code).
#
# Activate once per clone (it is NOT on by default -- git won't run repo-tracked hooks unaided):
#   git config core.hooksPath .githooks
#
# build-bundle.py is stdlib-only and byte-deterministic, so this rebuild is fast and reproducible.
set -euo pipefail

staged=$(git diff --cached --name-only)
if echo "$staged" | grep -qE '^(libraries/.*\.groovy|tools/build-bundle\.py)$'; then
  echo "pre-commit: a library or the bundle builder changed -> rebuilding bundles/mcp-libraries.zip ..."
  python3 tools/build-bundle.py
  git add bundles/mcp-libraries.zip
  echo "pre-commit: bundle rebuilt and staged."
fi
